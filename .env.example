# Veritabani (Coolify PostgreSQL)
DATABASE_URL="postgresql://vorte:GUCLU_SIFRE@localhost:5432/vortestudio"

# Auth
NEXTAUTH_SECRET="cok-uzun-rastgele-gizli-string-min-32-karakter"
NEXTAUTH_URL="https://studio.vorte.com.tr"
ADMIN_PASSWORD_HASH="bcrypt-hash-buraya"
# NOT: Hash icindeki $ isaretleri \$ ile escape edilmeli!
# Ornek: ADMIN_PASSWORD_HASH="\$2b\$12\$abc..."

# Google Maps Scraper (ic ag — Coolify'da otomatik)
SCRAPER_URL="http://gmaps-scraper:8080"

# Google PageSpeed (console.cloud.google.com — ucretsiz)
PAGESPEED_API_KEY=""

# Resend (resend.com — ucretsiz 3000/ay)
RESEND_API_KEY=""
FROM_EMAIL="studio@vorte.com.tr"

# Public
NEXT_PUBLIC_SITE_URL="https://studio.vorte.com.tr"

# Google Analytics 4 (analytics.google.com'dan al)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Node
NODE_ENV="production"
