generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Kullanıcı ──
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

// ── Müşteri ──
model Client {
  id           String       @id @default(cuid())
  name         String
  company      String?
  email        String?
  phone        String?
  sector       String?
  status       ClientStatus @default(POTENTIAL)
  notes        String?
  totalRevenue Float        @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  projects    Project[]
  quotes      Quote[]
  maintenance Maintenance[]
  activities  Activity[]
}

enum ClientStatus {
  POTENTIAL
  ACTIVE
  MAINTENANCE
  INACTIVE
}

// ── Lead ──
model Lead {
  id            String     @id @default(cuid())
  name          String
  company       String?
  email         String?
  phone         String?
  website       String?
  address       String?
  sector        String?
  source        LeadSource @default(MANUAL)
  status        LeadStatus @default(COLD)
  score         Int        @default(0)
  budget        String?
  notes         String?
  googleRating  Float?
  googleReviews Int?
  googleMapsUrl String?
  mobileScore   Int?
  hasWebsite    Boolean    @default(false)
  sslValid      Boolean    @default(false)

  // WA şablon sistemi
  waTemplate       String?   @db.Text  // Hazırlanan WA mesaj metni
  waTemplateSector String?              // Hangi sektör şablonu kullanıldı
  waTemplateSlug   String?              // Şablon slug'ı (ör: firinlar)
  waSentAt         DateTime?            // WA gönderim tarihi

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  chatSubmissions ChatSubmission[]
}

enum LeadSource {
  MAPS_SCRAPER
  SITE_FORM
  LINKEDIN
  REFERRAL
  MANUAL
}

enum LeadStatus {
  COLD
  TEMPLATE_ADDED
  WA_SENT
  CONTACTED
  MEETING
  QUOTED
  WON
  LOST
}

// ── Chatbot Başvuru ──
model ChatSubmission {
  id              String   @id @default(cuid())
  leadId          String?
  lead            Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  slug            String                // hangi demo sayfasından geldi
  firmName        String                // ziyaret edilen firma adı
  contactName     String?               // müşterinin verdiği isim
  contactPhone    String?               // telefon
  siteType        String?               // tanitim/e-ticaret/portfoy/randevu/katalog
  features        Json     @default("[]") // seçilen özellikler (string array)
  pageCount       String?               // 1-5/5-10/10+/siz-karar-verin
  contentStatus   String?               // hazir/logo-var/hicbir-sey-yok/mevcut-site
  hostingStatus   String?               // var/yok/bilmiyor
  hostingProvider String?               // müşterinin mevcut hosting firması
  domainStatus    String?               // var/yok/bilmiyor
  domainName      String?               // müşterinin mevcut domain'i
  timeline        String?               // acil/1-ay/2-3-ay/esnek
  message         String?  @db.Text     // ek not
  sector          String?
  city            String?
  completedSteps  Int      @default(0)  // kaçıncı adıma kadar geldi (1-12)
  score           String   @default("cold") // hot/warm/cold
  calculatedPrice Float?                // otomatik hesaplanan fiyat (TL)
  estimatedHours  Float?                // tahmini toplam saat
  tokenCost       Float?                // AI token maliyeti (TL)
  freeQuestions   Json     @default("[]")  // [{question, answer, step, timestamp}]
  isRead          Boolean  @default(false) // admin okudu mu
  createdAt       DateTime @default(now())
}

// ── Fiyat Ayarları ──
model PricingConfig {
  id        String   @id @default(cuid())
  category  String   // labor, base, feature, content, hosting, urgency, token
  key       String   @unique // ör: base_tanitim, feature_randevu, urgency_acil
  label     String   // Türkçe etiket
  value     Float    // fiyat (TL), saat, veya çarpan
  unit      String?  // saat, tl, carpan, dolar
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// ── Prospect (Maps Scraper sonuçları) ──
model ProspectBatch {
  id         String     @id @default(cuid())
  query      String
  city       String
  category   String
  totalFound Int        @default(0)
  status     String     @default("pending")
  createdAt  DateTime   @default(now())

  prospects Prospect[]
}

model Prospect {
  id            String        @id @default(cuid())
  batchId       String
  batch         ProspectBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  name          String
  phone         String?
  email         String?
  website       String?
  address       String?
  googleRating  Float?
  googleReviews Int?
  googleMapsUrl String?
  mobileScore   Int?
  hasWebsite    Boolean       @default(false)
  score         Int           @default(0)
  issue         String?
  addedToLeads  Boolean       @default(false)
  createdAt     DateTime      @default(now())

  pages ProspectPage[]
}

// ── Prospect Landing Sayfası ──
model ProspectPage {
  id         String   @id @default(cuid())
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  slug       String   @unique
  template   String
  sector     String
  city       String
  viewCount  Int      @default(0)
  chatCount  Int      @default(0)
  demoCount  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  events ProspectEvent[]
}

// ── Şablon Görselleri ──
model TemplateImage {
  id         String   @id @default(cuid())
  templateId String   // "dis-klinikleri", "veteriner-klinikleri" vb.
  slot       String   // "hero", "cta", "gallery_1"
  url        String
  prompt     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([templateId, slot])
}

// ── Prospect Sayfa Eventleri ──
model ProspectEvent {
  id        String       @id @default(cuid())
  pageId    String
  page      ProspectPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      String
  metadata  Json?
  createdAt DateTime     @default(now())
}

// ── Proje ──
model Project {
  id        String        @id @default(cuid())
  title     String
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type      ProjectType
  status    ProjectStatus @default(DISCOVERY)
  budget    Float
  startDate DateTime?
  deadline  DateTime?
  progress  Int           @default(0)
  techStack String[]
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  payments   Payment[]
  milestones Milestone[]
  activities Activity[]
}

enum ProjectType {
  WEBSITE
  ECOMMERCE
  MOBILE_APP
  REDESIGN
  CUSTOM
}

enum ProjectStatus {
  DISCOVERY
  DESIGN
  DEVELOPMENT
  TESTING
  DELIVERED
  ARCHIVED
}

// ── Milestone ──
model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  completed   Boolean   @default(false)
  dueDate     DateTime?
  completedAt DateTime?
}

// ── Teklif ──
model Quote {
  id          String      @id @default(cuid())
  clientId    String
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  packageType String
  basePrice   Float
  addons      Json        @default("[]")
  total       Float
  status      QuoteStatus @default(DRAFT)
  validUntil  DateTime?
  sentAt      DateTime?
  createdAt   DateTime    @default(now())
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
}

// ── Ödeme ──
model Payment {
  id        String        @id @default(cuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  amount    Float
  type      PaymentType
  dueDate   DateTime
  paidAt    DateTime?
  status    PaymentStatus @default(PENDING)
  invoiceNo String?
  notes     String?
  createdAt DateTime      @default(now())
}

enum PaymentType {
  DEPOSIT
  MILESTONE
  FINAL
  MAINTENANCE
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

// ── Bakım Paketi ──
model Maintenance {
  id           String    @id @default(cuid())
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  websiteUrl   String
  monthlyFee   Float
  startDate    DateTime
  renewalDate  DateTime
  domainExpiry DateTime?
  sslExpiry    DateTime?
  plan         String    @default("standard")
  notes        String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
}

// ── Portföy (public site) ──
model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  thumbnail   String?
  liveUrl     String?
  techStack   String[]
  featured    Boolean  @default(false)
  order       Int      @default(0)
  category    String?
  caseStudy   String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ── Aktivite Logu ──
model Activity {
  id          String   @id @default(cuid())
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  type        String
  description String
  createdAt   DateTime @default(now())
}

// ── Site Ayarları ──
model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ── Blog ──
model BlogPost {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  excerpt        String?
  content        String    @db.Text
  coverImage     String?
  seoTitle       String?
  seoDescription String?
  published      Boolean   @default(false)
  publishedAt    DateTime?
  authorName     String    @default("Vorte Studio")
  tags           String[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
