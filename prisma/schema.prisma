generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Kullanıcı ──
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

// ── Müşteri ──
model Client {
  id           String       @id @default(cuid())
  name         String
  company      String?
  email        String?
  phone        String?
  sector       String?
  status       ClientStatus @default(POTENTIAL)
  notes        String?
  totalRevenue Float        @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  projects    Project[]
  quotes      Quote[]
  maintenance Maintenance[]
  activities  Activity[]
}

enum ClientStatus {
  POTENTIAL
  ACTIVE
  MAINTENANCE
  INACTIVE
}

// ── Lead ──
model Lead {
  id            String     @id @default(cuid())
  name          String
  company       String?
  email         String?
  phone         String?
  website       String?
  address       String?
  sector        String?
  source        LeadSource @default(MANUAL)
  status        LeadStatus @default(COLD)
  score         Int        @default(0)
  budget        String?
  notes         String?
  googleRating  Float?
  googleReviews Int?
  googleMapsUrl String?
  mobileScore   Int?
  hasWebsite    Boolean    @default(false)
  sslValid      Boolean    @default(false)

  // WA şablon sistemi
  waTemplate       String?   @db.Text  // Hazırlanan WA mesaj metni
  waTemplateSector String?              // Hangi sektör şablonu kullanıldı
  waTemplateSlug   String?              // Şablon slug'ı (ör: firinlar)
  waSentAt         DateTime?            // WA gönderim tarihi

  // ── Kaynak izleme (Sprint 3.5) ──
  // source enum "kaba kategori"; aşağıdakiler ROI/attribution için detay.
  // Hepsi nullable — eski lead'lerde boş kalır, yeni akışlarda doldurulur.
  sourceDetail  String?  // "prospect:firinlar-ankara" | "contact-form" | "chat:slug"
  sourceUrl     String?  // Geliş sayfası pathname + query
  referrer      String?  // document.referrer (boşsa direct)
  utmSource     String?  // google | facebook | instagram | newsletter
  utmMedium     String?  // cpc | organic | email | referral
  utmCampaign   String?  // kampanya id/adı

  // Sprint 3.6d: /demo/[slug]?ref=<leadId> her ziyarette atomic increment
  viewCount     Int        @default(0)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  chatSubmissions ChatSubmission[]
  statusHistory   LeadStatusHistory[]
  duplicateLogs   LeadDuplicateLog[]
  optOutLogs      LeadOptOutLog[]
}

// ── Lead Dublike Log (Sprint 3.6a) ──
// Scraper/manual ekleme akışında reddedilen duplicate denemelerinin
// audit kaydı. UI'da "Atlanan: N" sayacı + debug için kullanılır.
// FK CASCADE: eşleşilen lead silinirse log da gider.
model LeadDuplicateLog {
  id                     String   @id @default(cuid())
  attemptedName          String
  attemptedPhone         String?
  attemptedGoogleMapsUrl String?
  attemptedSector        String?
  matchedLeadId          String
  matchedLead            Lead     @relation(fields: [matchedLeadId], references: [id], onDelete: Cascade)
  matchReason            String   // GOOGLE_MAPS_URL | PHONE | NAME_SECTOR
  duplicateSource        String   // MAPS_SCRAPER | MANUAL_ADMIN
  createdAt              DateTime @default(now())

  @@index([matchedLeadId])
  @@index([createdAt])
}

// ── Lead Status Geçmişi (Sprint 3.2) ──
// Status değişimlerinin audit log'u. Satış funnel analytics + retrospektif.
// Idempotency: aynı status'a geçişte yazmaz (kanban drag gürültüsü önlenir).
model LeadStatusHistory {
  id         String      @id @default(cuid())
  leadId     String
  lead       Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStatus LeadStatus?  // ilk oluşturmada null
  toStatus   LeadStatus
  changedBy  String?     // admin email, "system", veya "admin" fallback
  reason     String?     // "manual" | "wa_template_added" | "wa_sent" | "contract_signed" | "client_conversion" | "lead_created" | "opt_out"
  createdAt  DateTime    @default(now())

  @@index([leadId, createdAt])
}

// ── Lead Opt-Out Log (Sprint 3.6d) ──
// KVKK m.7 veri silme talebinin delil kaydı. Lead SİLİNMEZ, status=OPTED_OUT
// olur. Bu log 10 yıl saklanır (KVKK m.13 başvuru delili) ve FK ON DELETE
// RESTRICT nedeniyle lead silme DB seviyesinde engellenir — hukuki kale.
model LeadOptOutLog {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Restrict)
  firmName  String   // opt-out anında lead.name — lead ileride rename olursa da delil net
  ip        String?
  userAgent String?
  reason    String?  // kullanıcının opsiyonel serbest metin geri bildirimi (max 500ch)
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
}

enum LeadSource {
  MAPS_SCRAPER
  SITE_FORM
  LINKEDIN
  REFERRAL
  MANUAL
}

enum LeadStatus {
  COLD
  TEMPLATE_ADDED
  WA_SENT
  CONTACTED
  MEETING
  QUOTED
  CONTRACTED
  WON
  LOST
  OPTED_OUT  // Sprint 3.6d: KVKK m.7 veri silme talebi (lead silinmez, status geçer)
}

// ── Chatbot Başvuru ──
model ChatSubmission {
  id              String   @id @default(cuid())
  leadId          String?
  lead            Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  slug            String                // hangi demo sayfasından geldi
  firmName        String                // ziyaret edilen firma adı
  contactName     String?               // müşterinin verdiği isim
  contactPhone    String?               // telefon
  contactEmail    String?               // e-posta
  siteType        String?               // tanitim/e-ticaret/portfoy/randevu/katalog
  features        Json     @default("[]") // seçilen özellikler (string array)
  pageCount       String?               // 1-5/5-10/10+/siz-karar-verin
  contentStatus   String?               // hazir/logo-var/hicbir-sey-yok/mevcut-site
  hostingStatus   String?               // var/yok/bilmiyor
  hostingProvider String?               // müşterinin mevcut hosting firması
  domainStatus    String?               // var/yok/bilmiyor
  domainName      String?               // müşterinin mevcut domain'i
  timeline        String?               // acil/1-ay/2-3-ay/esnek
  businessGoals   String?  @db.Text     // is hedefleri / site amaci
  targetAudience  String?  @db.Text     // hedef kitle tanimi
  referenceUrls   Json     @default("[]") // begenilen referans siteler (string array)
  brandColors     String?               // marka renkleri / stil tercihi
  seoExpectations String?               // SEO beklentileri
  existingSiteUrl String?               // mevcut site URL (contentStatus=mevcut-site ise)
  logoStatus      String?               // var, yok, tasarimci
  socialMediaLinks String? @db.Text     // sosyal medya hesap linkleri
  liveSupportType String?               // whatsapp, tawkto, crisp, kararsiz
  paymentProvider String?               // iyzico, paytr, baska, kararsiz
  message         String?  @db.Text     // ek not
  sector          String?
  city            String?
  completedSteps  Int      @default(0)  // kaçıncı adıma kadar geldi (1-12)
  score           String   @default("cold") // hot/warm/cold
  calculatedPrice Float?                // otomatik hesaplanan fiyat (TL) — iç tahmin
  estimatedHours  Float?                // tahmini toplam saat
  tokenCost       Float?                // AI token maliyeti (TL)
  suggestedPackage String?              // starter/profesyonel/eticaret/kurumsal — paket önerisi
  freeQuestions   Json     @default("[]")  // [{question, answer, step, timestamp}]
  isRead          Boolean  @default(false) // admin okudu mu
  // ── KVKK Açık Rıza (6698 m.10) ──
  kvkkAcceptedAt      DateTime? // onay zaman damgası
  kvkkVersion         String?   // onaylanan metin versiyonu (lib/kvkk-constants.ts)
  kvkkAcceptIp        String?   // onay anındaki istemci IP (x-forwarded-for ilk parça)
  kvkkAcceptUserAgent String?   @db.Text // onay anındaki User-Agent
  createdAt       DateTime @default(now())

  proposals Proposal[]
}

// ── Teklif (Müşteriye gönderilen) ──
model Proposal {
  id              String         @id @default(cuid())
  token           String         @unique @default(cuid()) // public URL token
  submissionId    String?
  submission      ChatSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  leadId          String?

  // Firma bilgileri (submission'dan kopyalanır, bağımsız kalır)
  firmName        String
  contactName     String?
  contactPhone    String?
  contactEmail    String?
  sector          String?
  city            String?

  // Proje detayları
  siteType        String?
  features        Json           @default("[]")
  pageCount       String?
  contentStatus   String?
  hostingStatus   String?
  hostingProvider String?
  domainStatus    String?
  domainName      String?
  timeline        String?

  // Zenginleştirilmiş bilgiler (submission'dan kopyalanır)
  brandColors     String?
  businessGoals   String?        @db.Text
  targetAudience  String?        @db.Text

  // Fiyatlandırma
  items           Json           @default("[]") // fiyat kırılımı [{label, hours, cost}]
  totalPrice      Float
  estimatedHours  Float?
  paymentPlan     Json           @default("[]") // [{label, percent, amount, description}]

  // Durum
  status          ProposalStatus @default(DRAFT)
  validUntil      DateTime       // geçerlilik süresi
  adminNotes      String?        @db.Text
  viewedAt        DateTime?      // müşteri ilk görüntülediğinde
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  sentAt          DateTime?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  contract        Contract?
  payments        ProposalPayment[]
  portalUser      PortalUser?
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

// ── Sözleşme (Dijital İmza) ──
model Contract {
  id            String         @id @default(cuid())
  proposalId    String         @unique
  proposal      Proposal       @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  // İmzalayan kişi bilgileri
  signerName    String                // Ad Soyad
  signerTcNo    String?               // TC Kimlik No (şahıs)
  signerTaxNo   String?               // Vergi No (tüzel kişi)
  signerTitle   String?               // Ünvan/Pozisyon (Şirket Sahibi, Müdür vb.)
  signerCompany String?               // Şirket Ünvanı (tüzel kişi ise)
  signerEmail   String                // Doğrulanmış e-posta
  signerPhone   String?               // Telefon
  signerAddress String?               // Adres

  // Sözleşme içeriği
  contractText  String         @db.Text   // Tam sözleşme metni
  contractHash  String                    // SHA-256 hash (değiştirilmediğinin kanıtı)

  // Dijital imza
  signatureData String?        @db.Text   // base64 canvas imza görseli
  signedAt      DateTime?               // İmza tarihi

  // Metadata (hukuki delil)
  signerIp      String?               // İmzalayanın IP adresi
  signerAgent   String?               // User-Agent (tarayıcı/cihaz)
  signerDevice  String?               // Ekran çözünürlüğü

  // Doğrulama
  emailVerified Boolean        @default(false)

  // Durum
  status        ContractStatus @default(PENDING)

  // ── Kalıcı veri saklayıcısı delili (Mesafeli Sözl. Yönetmeliği m.5/1-a, m.6) ──
  // Tüketici "bana gelmedi" iddia ederse DB'de kanıt olmalı; SMTP logları
  // kısa sürede rotate olur, bu alanlar 10 yıl kalır.
  pdfSentAt          DateTime? // Hizmet sözleşmesi PDF'i maile eklenip gönderildiği an
  mesafeliPdfSentAt  DateTime? // Mesafeli Satış PDF'i gönderildiği an (ayrı delil)
  pdfSendError       String?   @db.Text // Son gönderim hatası (varsa) — admin bildirimi için

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum ContractStatus {
  PENDING     // İmza bekleniyor
  SIGNED      // İmzalandı
  CANCELLED   // İptal edildi
}

// ── E-posta Doğrulama Kodu ──
model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String               // 6 haneli kod
  type      String               // "contract"
  expiresAt DateTime             // Süre dolumu (10 dk)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ── E-posta Doğrulama Rate Limit Takibi (FAZ A — Madde 1.5) ──
//
// verifyContractEmail Server Action'ı her çağrıldığında (başarılı/başarısız)
// bir satır yazar. Brute force koruması:
//   • 15 dk pencere içinde en fazla 5 deneme
//   • 5 başarısız deneme sonrası 1 saat kilit
//
// Retention: KVKK m.5/2-f meşru menfaat (güvenlik denetimi) — cleanup job'u
// eklenene kadar manuel temizlenir. PII minimum: e-posta + IP + UA (500ch
// truncate). Hash YOK çünkü rate limit sorguları email üzerinden çalışır.
//
// FK yok: contract silinse de denetim izi kalmalı (attempt history).
model EmailVerificationAttempt {
  id          String   @id @default(cuid())
  email       String
  attemptedAt DateTime @default(now())
  ip          String?
  userAgent   String?
  success     Boolean

  @@index([email, attemptedAt])    // Rate limit window sorguları
  @@index([attemptedAt])           // Cleanup job için
}

// ── Teklif Ödeme Takibi ──
model ProposalPayment {
  id         String   @id @default(cuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  stage      Int                  // 1=Peşinat, 2=Ara Ödeme, 3=Final
  label      String               // "Peşinat (%40)"
  amount     Float                // Beklenen tutar (KDV dahil)
  paidAt     DateTime?            // Ödeme tarihi
  status     String   @default("PENDING") // PENDING, PAID
  notes      String?              // Ödeme notu
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Müşteri Portal Kullanıcısı ──
model PortalUser {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  proposalId    String    @unique
  proposal      Proposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  firmName      String
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // ── Tasarım Önizleme (Staging) ──
  // Admin staging URL'i buraya yazar, müşteri /portal/tasarim'da görür.
  // designApprovedAt dolarsa tasarım kilitlenir — yeni revizyon alınamaz.
  stagingUrl       String?
  designApprovedAt DateTime?

  messages        PortalMessage[]
  files           PortalFile[]
  logoProject     LogoProject?
  designRevisions DesignRevision[]
  passwordResets  PortalPasswordReset[]
}

// ── Portal Şifre Sıfırlama Token ──
//
// Müşteri "Şifremi Unuttum" akışı için tek-kullanımlık, TTL'li token.
// Token hash'lenmez — kısa ömürlü (60 dk) ve tek-kullanımlık olduğu için
// DB sızıntısında risk sınırlı. E-posta ile gönderilen link /portal/sifre/[token]
// route'una yönlendirir; token valid + unused + not expired ise yeni şifre
// ekranı gösterilir.
//
// used=true ya da expiresAt geçtikten sonra cleanup job gerekmez —
// aramalar where expiresAt { gte: now(), used: false } ile filtreler.
model PortalPasswordReset {
  id           String     @id @default(cuid())
  portalUserId String
  portalUser   PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  token        String     @unique
  expiresAt    DateTime
  used         Boolean    @default(false)
  createdAt    DateTime   @default(now())
  ipAddress    String?

  @@index([portalUserId, createdAt])
}

// ── Tasarım Revizyon Talepleri ──
// Append-only audit trail. Sayım count() ile hesaplanır — race-safe, counter field yok.
// Sözleşmede 3 revizyon hakkı var (lib/design-preview-rules.ts → MAX_DESIGN_REVISIONS).
model DesignRevision {
  id               String     @id @default(cuid())
  portalUserId     String
  portalUser       PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  note             String     @db.Text // Müşterinin revizyon notu
  stagingUrlAtTime String?             // Talep anındaki staging URL snapshot'ı
  createdAt        DateTime   @default(now())

  @@index([portalUserId, createdAt])
}

// ── Portal Mesajları ──
model PortalMessage {
  id           String     @id @default(cuid())
  portalUserId String
  portalUser   PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  content      String     @db.Text
  senderType   String     // CUSTOMER | ADMIN
  isRead       Boolean    @default(false)
  createdAt    DateTime   @default(now())
}

// ── Portal Dosyaları ──
model PortalFile {
  id           String     @id @default(cuid())
  portalUserId String
  portalUser   PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  fileName     String
  filePath     String
  fileSize     Int        // byte
  fileType     String     // mime type
  uploadedBy   String     // CUSTOMER | ADMIN
  description  String?
  createdAt    DateTime   @default(now())
}

// ── Logo Projesi ──
model LogoProject {
  id              String   @id @default(cuid())
  portalUserId    String   @unique
  portalUser      PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  firmName        String
  firmSlug        String?  @unique     // ASCII slug — brand asset klasoru icin (orn. "vorte-tekstil")
  sector          String?
  style           String?           // minimal, modern, vintage, playful
  brandColors     String?           // serbest metin (legacy / fallback)
  includeText     Boolean  @default(true) // logoda firma adı olsun mu
  notes           String?  @db.Text // admin notları

  // Marka kiti — HEX renkler (yeni primary kanal)
  primaryColor    String?           // #hex (ana marka rengi)
  secondaryColor  String?           // #hex (ikincil marka rengi)
  accentColor     String?           // #hex (vurgu rengi)
  fontDisplay     String?           // başlık fontu
  fontBody        String?           // gövde fontu
  brandGuidelines String?  @db.Text // kullanım kuralları

  // Onaylanan logo (legacy: tek dosya yolu)
  approvedLogoUrl String?           // /uploads/brand/[slug]/primary-1024.png
  approvedAt      DateTime?

  // Brand asset bundle manifest yolu (post-process sonrasi)
  brandManifestUrl String?          // /uploads/brand/[slug]/manifest.json

  status          String   @default("DRAFT") // DRAFT, GENERATING, REVIEW, APPROVED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  variants LogoVariant[]
}

// ── Logo Varyantları ──
model LogoVariant {
  id            String      @id @default(cuid())
  logoProjectId String
  logoProject   LogoProject @relation(fields: [logoProjectId], references: [id], onDelete: Cascade)
  url           String                // /uploads/logos/[projectId]/variant-X.png
  prompt        String?    @db.Text   // kullanılan AI prompt
  model         String?               // hangi AI modeli üretti
  isApproved    Boolean    @default(false)
  feedback      String?    @db.Text   // müşteri geri bildirimi
  feedbackAt    DateTime?
  createdAt     DateTime   @default(now())
}

// ── Fiyat Ayarları ──
model PricingConfig {
  id        String   @id @default(cuid())
  category  String   // labor, base, feature, content, hosting, urgency, token
  key       String   @unique // ör: base_tanitim, feature_randevu, urgency_acil
  label     String   // Türkçe etiket
  value     Float    // fiyat (TL), saat, veya çarpan
  unit      String?  // saat, tl, carpan, dolar
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// ── Prospect (Maps Scraper sonuçları) ──
model ProspectBatch {
  id         String     @id @default(cuid())
  query      String
  city       String
  category   String
  totalFound Int        @default(0)
  status     String     @default("pending")
  createdAt  DateTime   @default(now())

  prospects Prospect[]
}

model Prospect {
  id            String        @id @default(cuid())
  batchId       String
  batch         ProspectBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  name          String
  phone         String?
  email         String?
  website       String?
  address       String?
  googleRating  Float?
  googleReviews Int?
  googleMapsUrl String?
  mobileScore   Int?
  hasWebsite    Boolean       @default(false)
  score         Int           @default(0)
  issue         String?
  addedToLeads  Boolean       @default(false)
  createdAt     DateTime      @default(now())

  pages ProspectPage[]
}

// ── Prospect Landing Sayfası ──
model ProspectPage {
  id         String   @id @default(cuid())
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  slug       String   @unique
  template   String
  sector     String
  city       String
  viewCount  Int      @default(0)
  chatCount  Int      @default(0)
  demoCount  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  events ProspectEvent[]
}

// ── Prospect Opt-Out (KVKK veri silme talepleri) ──
// Prospect'e ait landing sayfası üzerinden "Verimi Sil" butonuyla tetiklenir.
// ProspectPage.isActive → false çekilir AMA bu tablo silinmez: uyuşmazlıkta
// "şu tarihte şu IP'den talep geldi, 30 gün içinde karşıladık" delili olarak
// KVKK m.13 başvuru usulüne uygunluğu kanıtlar.
model ProspectOptOut {
  id         String   @id @default(cuid())
  prospectId String?  // opt-out anında hala mevcutsa; sonra silinebilir
  slug       String   // her zaman korunur (prospect silinse bile delil için)
  firmName   String   // hangi firma talep etti (kanıt)
  ip         String?  // talep edenin IP'si
  userAgent  String?  @db.Text
  reason     String?  @db.Text // opsiyonel — "neden" alanı varsa
  createdAt  DateTime @default(now())

  @@index([slug])
  @@index([createdAt])
}

// ── Şablon Görselleri ──
model TemplateImage {
  id         String   @id @default(cuid())
  templateId String   // "dis-klinikleri", "veteriner-klinikleri" vb.
  slot       String   // "hero", "cta", "gallery_1"
  url        String
  prompt     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([templateId, slot])
}

// ── Prospect Sayfa Eventleri ──
model ProspectEvent {
  id        String       @id @default(cuid())
  pageId    String
  page      ProspectPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      String
  metadata  Json?
  createdAt DateTime     @default(now())
}

// ── Proje ──
model Project {
  id        String        @id @default(cuid())
  title     String
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type      ProjectType
  status    ProjectStatus @default(DISCOVERY)
  budget    Float
  startDate DateTime?
  deadline  DateTime?
  progress  Int           @default(0)
  techStack String[]
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  payments   Payment[]
  milestones Milestone[]
  activities Activity[]
}

enum ProjectType {
  WEBSITE
  ECOMMERCE
  MOBILE_APP
  REDESIGN
  CUSTOM
}

enum ProjectStatus {
  DISCOVERY
  DESIGN
  DEVELOPMENT
  TESTING
  DELIVERED
  ARCHIVED
}

// ── Milestone ──
model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  completed   Boolean   @default(false)
  dueDate     DateTime?
  completedAt DateTime?
  approvedAt  DateTime?            // müşteri onay tarihi
  approvedBy  String?              // onaylayan müşteri adı
}

// ── Teklif ──
model Quote {
  id          String      @id @default(cuid())
  clientId    String
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  packageType String
  basePrice   Float
  addons      Json        @default("[]")
  total       Float
  status      QuoteStatus @default(DRAFT)
  validUntil  DateTime?
  sentAt      DateTime?
  createdAt   DateTime    @default(now())
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
}

// ── Ödeme ──
model Payment {
  id        String        @id @default(cuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  amount    Float
  type      PaymentType
  dueDate   DateTime
  paidAt    DateTime?
  status    PaymentStatus @default(PENDING)
  invoiceNo String?
  notes     String?
  createdAt DateTime      @default(now())
}

enum PaymentType {
  DEPOSIT
  MILESTONE
  FINAL
  MAINTENANCE
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

// ── Bakım Paketi ──
model Maintenance {
  id           String    @id @default(cuid())
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  websiteUrl   String
  monthlyFee   Float
  startDate    DateTime
  renewalDate  DateTime
  domainExpiry DateTime?
  sslExpiry    DateTime?
  plan         String    @default("standard")
  notes        String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
}

// ── Portföy (public site) ──
model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  thumbnail   String?
  liveUrl     String?
  techStack   String[]
  featured    Boolean  @default(false)
  order       Int      @default(0)
  category    String?
  caseStudy   String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ── Aktivite Logu ──
model Activity {
  id          String   @id @default(cuid())
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  type        String
  description String
  createdAt   DateTime @default(now())
}

// ── Site Ayarları ──
model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ── Blog ──
model BlogPost {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  excerpt        String?
  content        String    @db.Text
  coverImage     String?
  seoTitle       String?
  seoDescription String?
  published      Boolean   @default(false)
  publishedAt    DateTime?
  authorName     String    @default("Vorte Studio")
  tags           String[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ── WhatsApp Mesaj Logu ──
model WhatsAppLog {
  id          String   @id @default(cuid())
  phone       String              // hedef telefon (90XXXXXXXXXX)
  recipientName String?           // alıcı adı
  template    String              // şablon adı (teklif_gonderildi, sozlesme_imzalandi vb.)
  message     String   @db.Text   // gönderilen mesaj metni
  context     String?             // bağlam (lead ID, proposal ID vb.)
  contextType String?             // LEAD, PROPOSAL, CONTRACT, PORTAL
  contextId   String?             // ilgili kaydın ID'si
  sentBy      String   @default("ADMIN") // ADMIN | SYSTEM
  createdAt   DateTime @default(now())
}

// ── Sesli Arama Kayıtları (Voice AI) ──
model CallLog {
  id              String    @id @default(cuid())
  callId          String    @unique
  callerNumber    String
  callDirection   String    @default("inbound")
  status          String    @default("completed")
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int       @default(0)
  topics          String[]
  summary         String?
  sentiment       String?
  transcript      Json?
  audioUrl        String?
  transferredTo   String?
  isRead          Boolean   @default(false)
  notes           String?
  emailSent       Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@map("call_logs")
}

// ── FCM Cihaz Token'ları (Push Notification) ──
model DeviceToken {
  id        String   @id @default(cuid())
  token     String   @unique
  platform  String   @default("android")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("device_tokens")
}
